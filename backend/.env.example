# ═══════════════════════════════════════════════════════════════
#   ClosetAI — Variables de Entorno
#   Copia este archivo como .env y rellena con tus valores reales
# ═══════════════════════════════════════════════════════════════

# ── Supabase ────────────────────────────────────────────────────
# Encuéntralos en: supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # anon/public key
SUPABASE_JWT_SECRET=tu-jwt-secret-aqui                  # Settings → API → JWT Secret

# ── Base de Datos (conexión directa) ────────────────────────────
# Encuéntralo en: Supabase → Settings → Database → Connection string
# Cambia [YOUR-PASSWORD] por tu contraseña de base de datos
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.TU_PROJECT_ID.supabase.co:5432/postgres

# ── Supabase Storage ────────────────────────────────────────────
SUPABASE_STORAGE_BUCKET=garment-images

# ── Groq API (LLM gratuito) ─────────────────────────────────────
# Regístrate gratis en: console.groq.com → API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama3-70b-8192

# ── OpenWeatherMap ──────────────────────────────────────────────
# Regístrate gratis en: openweathermap.org → My API Keys
OPENWEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Entorno ─────────────────────────────────────────────────────
APP_ENV=development   # Cambiar a "production" en Render
